# .claudeignore — Claude Code 解析除外ファイル
# 機密・巨大・不要ファイルをコンテキストから除外する

# =============================================================
# 認証情報・シークレット（最優先）
# =============================================================
.env
.env.*
.env.local
secrets/
credentials
*.pem
*.key
*.p12
*_rsa
*_ed25519
*.secret

# =============================================================
# 依存パッケージ（巨大・解析不要）
# =============================================================
node_modules/
vendor/
.venv/
venv/
env/
__pycache__/
*.pyc

# =============================================================
# ビルド・成果物
# =============================================================
dist/
build/
out/
target/
bin/
*.o
*.so
*.dll
*.exe

# =============================================================
# ログ・一時ファイル
# =============================================================
*.log
logs/
tmp/
temp/
.tmp/
*.tmp
*.swp
.DS_Store
Thumbs.db

# =============================================================
# テスト・カバレッジ出力
# =============================================================
coverage/
.coverage
htmlcov/
.pytest_cache/
junit*.xml
test-results/

# =============================================================
# CI/CD・キャッシュ
# =============================================================
.cache/
.next/
.nuxt/
.turbo/
.parcel-cache/

# =============================================================
# IDE・エディタ
# =============================================================
.idea/
.vscode/settings.json
*.iml

# =============================================================
# Git
# =============================================================
.git/
