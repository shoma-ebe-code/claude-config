# .claudeignore — SRE向け拡張版
# base/.claudeignore の内容に加えて IaC・クラウド固有の除外を追加

# =============================================================
# 認証情報・シークレット
# =============================================================
.env
.env.*
.env.local
secrets/
credentials
*.pem
*.key
*.p12
*.pfx
*_rsa
*_ed25519
*.secret
vault-token

# =============================================================
# Terraform / IaC
# =============================================================
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfplan
.terragrunt-cache/
terraform.tfvars
override.tf
override.tf.json

# =============================================================
# Kubernetes / Helm
# =============================================================
charts/*/charts/
charts/*/tmpcharts/
*.kubeconfig
kubeconfig

# =============================================================
# AWS・クラウド固有
# =============================================================
.aws/
samconfig.toml
cdk.out/
.serverless/

# =============================================================
# Docker
# =============================================================
.docker/
docker-compose.override.yml

# =============================================================
# 依存パッケージ
# =============================================================
node_modules/
vendor/
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo

# =============================================================
# ビルド・成果物
# =============================================================
dist/
build/
out/
target/
bin/
*.o
*.so
*.dll
*.exe

# =============================================================
# ログ・一時ファイル
# =============================================================
*.log
logs/
log/
tmp/
temp/
.tmp/
*.tmp
*.swp
.DS_Store
Thumbs.db

# =============================================================
# テスト・カバレッジ出力
# =============================================================
coverage/
.coverage
htmlcov/
.pytest_cache/
.tox/
junit*.xml
test-results/
*.lcov

# =============================================================
# CI/CD・キャッシュ
# =============================================================
.cache/
.gradle/
.m2/
.npm/
.yarn/cache/
.next/
.nuxt/
.turbo/
.parcel-cache/

# =============================================================
# IDE・エディタ
# =============================================================
.idea/
.vscode/settings.json
*.iml

# =============================================================
# データ・バックアップ（巨大）
# =============================================================
*.sql
*.dump
*.db
*.sqlite
backups/
backup/

# =============================================================
# Git
# =============================================================
.git/
